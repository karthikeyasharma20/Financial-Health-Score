# Database configuration
# For Docker Compose, the database host is "db"
DATABASE_URL=postgresql://postgres:postgrespassword@db:5432/financial_health
# For local fallback development:
# DATABASE_URL=sqlite:///./financial_health.db

# JWT Security
JWT_SECRET_KEY=supersecretkeythatshouldbechangedinproduction1234567890
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Machine Learning Config
ML_MODEL_PATH=/app/ml-model/model.pkl
ML_SCALER_PATH=/app/ml-model/scaler.pkl

# Frontend App Config
VITE_API_URL=http://localhost:8000
